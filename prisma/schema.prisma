generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id        String   @id @default(cuid())
  name      String?
  createdAt DateTime @default(now())

  tarotReadings TarotReading[]
  dailySigns    DailySign[]
  dreamEntries  DreamEntry[]
  constitution      Constitution?
  wellnessCheckins  WellnessCheckin[]
}

model TarotReading {
  id          String   @id @default(cuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])

  role        String   // yuejian | yousuo | qingwu | huohu
  topic       String?  // 用户问题主题
  description String?  // 用户补充描述
  spreadType  String   // single | three | celtic
  cards       String   // JSON序列化字符串（SQLite无原生Json）
  reading     String   // AI生成的完整解读文本
  narrative   String?  // 连续性叙事引用

  createdAt   DateTime @default(now())
}

model DailySign {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])

  date      String   // YYYY-MM-DD
  signText  String   // 今日一签文案
  insight   String?  // 洞察型奖励内容
  streak    Int      @default(1)
  createdAt DateTime @default(now())

  @@unique([userId, date])
}

// ========== 解梦模块 ==========
model DreamEntry {
  id          String   @id @default(cuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])

  content     String   // 梦境描述文本
  tags        DreamTag[]
  emotion     String?  // 情绪标记：fear/anxiety/joy/sadness/confusion/calm/absurd
  clarity     String?  // 清晰度：clear/partial/vague
  isRecurring Boolean  @default(false) // 是否反复出现
  traditional String?  // AI解析：传统寓意
  deeper      String?  // AI解析：深层映射
  questions   String?  // AI解析：值得自问
  feedback    String?  // 用户反馈：inspired/partial/none
  relatedNote String?  // 用户关联输入

  createdAt   DateTime @default(now())
}

model DreamTag {
  id      String     @id @default(cuid())
  name    String
  entryId String
  entry   DreamEntry @relation(fields: [entryId], references: [id])

  @@index([name])
}

// ========== 养元模块 ==========
model Constitution {
  id        String   @id @default(cuid())
  userId    String?  @unique
  user      User?    @relation(fields: [userId], references: [id])

  type      String   // 9种体质类型：pinghe/qixu/yangxu/yinxu/tanshi/shire/xueyu/qiyu/tebing
  scores    String   // JSON序列化的各维度得分
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

model WellnessCheckin {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])

  date      String   // YYYY-MM-DD
  type      String   // diet | exercise | sleep | custom
  content   String   // 打卡内容
  feedback  String?  // 体感反馈：better/normal/none
  createdAt DateTime @default(now())

  @@unique([userId, date, type])
}
